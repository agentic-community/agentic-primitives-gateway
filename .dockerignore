# Virtual environments
.venv
venv
env

# Node — we rebuild fresh inside the ui-builder stage, never copy host modules
**/node_modules

# Prebuilt UI output — regenerated by the ui-builder stage; stale host copies
# must not leak in and override the in-stage build
src/agentic_primitives_gateway/static

# tsc -b artifacts next to vite.config.ts
ui/vite.config.js
ui/vite.config.d.ts
ui/*.tsbuildinfo

# Not part of the gateway image
client
docs
site
examples
tests
deploy
scripts

# IDE / OS
.idea
.vscode
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Secrets / local config
.env
.env.*
*.pem
*.key

# Claude Code scratch
.claude
CLAUDE.md

# Other large/irrelevant
volumes
*.whl
*.tar.gz
*.pdf

# Intermediate docker artifacts
Dockerfile.*
docker-compose*.yml
